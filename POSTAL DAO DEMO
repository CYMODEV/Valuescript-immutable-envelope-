          </button>
          <button 
            onClick={() => setIsMobileMode(false)}
            className={`p-3 rounded-full shadow-xl border-2 transition-all ${!isMobileMode ? 'bg-amber-500 border-amber-400 text-slate-950 scale-110' : 'bg-slate-900 border-slate-800 text-slate-500'}`}
          >
              <Monitor className="w-5 h-5" />
          </button>
      </div>

      {isMobileMode && <BottomNav activeTab={activeTab} setActiveTab={setActiveTab} pendingCount={pendingCount} />}
    </div>
  );
};

export default App;


