                            <button onClick={() => onUnlockGeofence(stamp.uniqueId, true, {latitude:0, longitude:0})} className="mt-2 w-full py-1 bg-indigo-500/10 text-indigo-400 text-[10px] font-bold rounded border border-indigo-500/30 hover:bg-indigo-500/20 transition-colors">Unlock</button>
                        )}
                    </div>
                ))}
            </div>
        ) : (
            <div className="space-y-2">
                {transactions.slice().reverse().map(tx => (
                    <div key={tx.id} className="bg-slate-900 border border-slate-800 p-3 rounded-xl flex justify-between items-center hover:border-slate-700 transition-colors">
                        <div className="flex items-center gap-3">
                            <div className={`p-2 rounded-full ${tx.type === 'deposit' ? 'bg-emerald-500/10 text-emerald-500' : tx.type === 'withdraw' || tx.type === 'payout' ? 'bg-red-500/10 text-red-400' : 'bg-slate-800 text-slate-400'}`}>
                                {tx.type === 'deposit' ? <Plus className="w-4 h-4" /> : (tx.type === 'withdraw' || tx.type === 'payout') ? <LogOut className="w-4 h-4" /> : <Coins className="w-4 h-4" />}
                            </div>
                            <div>
                                <p className="text-xs font-bold text-slate-200">{tx.desc}</p>
                                <p className="text-[10px] text-slate-500">{tx.date}</p>
                            </div>
                        </div>
                        <span className={`font-mono text-xs font-bold ${tx.amount > 0 ? 'text-emerald-400' : 'text-slate-300'}`}>
                            {tx.amount > 0 ? '+' : ''}${Math.abs(tx.amount).toFixed(2)}
                        </span>
                    </div>
                ))}
            </div>
        )}
    </div>
    );
};

