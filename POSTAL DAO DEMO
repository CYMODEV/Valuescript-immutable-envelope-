            stampUniqueId: selectedStamp.uniqueId,
            isGeofenced: isSovereignMode && mailType === 'electronic',
            gpsCoordinates: isSovereignMode ? gpsCoords : null,
            docType: docType
        });
        setStep(4);
        setIsSealing(false);
    }, 1500);
  };

  const reset = () => {
      setStep(1);
      setMailType(null);
      setDocType(null);
      setSelectedStamp(null);
      setRecipient("");
      setMessage("");
      setGpsCoords({lat: "", lng: ""});
      setUtilityAddress("");
      setIsSovereignMode(false);
      setRiskReport(null);
      setVibeReport(null);
  };

  // STEP 1: Method & Type
  if (step === 1) return (
    <div className={`p-6 ${isMobileMode ? 'pt-28 pb-32' : 'pt-10'} animate-fade-in flex flex-col h-full`}>
      {/* ... (Same Step 1 Content) ... */}
      <div className="mb-8">
        <h2 className="text-2xl font-bold text-slate-100">New Dispatch</h2>
        <p className="text-slate-500 text-sm mt-1">Select secure custody protocol.</p>
      </div>
      
      <div className="grid grid-cols-2 gap-4 mb-6">
        <button onClick={() => setMailType('physical')} className={`p-4 rounded-2xl border transition-all text-left ${mailType === 'physical' ? 'bg-amber-500/10 border-amber-500/50' : 'bg-slate-900 border-slate-800'}`}>
          <Mail className={`w-6 h-6 mb-2 ${mailType === 'physical' ? 'text-amber-500' : 'text-slate-500'}`} />
          <h3 className="text-sm font-bold text-slate-200">Physical</h3>
        </button>
        <button onClick={() => setMailType('electronic')} className={`p-4 rounded-2xl border transition-all text-left ${mailType === 'electronic' ? 'bg-cyan-500/10 border-cyan-500/50' : 'bg-slate-900 border-slate-800'}`}>
          <Lock className={`w-6 h-6 mb-2 ${mailType === 'electronic' ? 'text-cyan-500' : 'text-slate-500'}`} />
          <h3 className="text-sm font-bold text-slate-200">Electronic</h3>
        </button>
      </div>

      {mailType && (
          <div className="space-y-3 animate-slide-up">
              <p className="text-xs font-bold text-slate-500 uppercase tracking-widest">Secure Custody Classification</p>
              {[{ id: 'Legal', icon: Scale, label: 'Legal (Notary)' }, { id: 'Financial', icon: Landmark, label: 'Financial (Bearer)' }, { id: 'Medical', icon: Stethoscope, label: 'Medical (HIPAA)' }, { id: 'Secret', icon: FileKey, label: 'Top Secret (Burn)' }].map(type => (
                  <button key={type.id} onClick={() => { setDocType(type.id); setStep(2); }} className="w-full p-4 rounded-xl bg-slate-900 border border-slate-800 flex items-center gap-4 hover:border-slate-600 transition-colors">
                      <div className="p-2 bg-slate-800 rounded-lg"><type.icon className="w-4 h-4 text-slate-300" /></div>
                      <span className="text-sm font-medium text-slate-200">{type.label}</span>
                      <ChevronRight className="w-4 h-4 text-slate-600 ml-auto" />
                  </button>
              ))}
          </div>
      )}
    </div>
  );

  if (step === 2) return (
     // ... (Same Step 2 Content, relying on prev logic) ...
    <div className={`p-6 ${isMobileMode ? 'pt-28 pb-32' : 'pt-10'} h-full flex flex-col animate-slide-up`}>
      <div className="flex items-center justify-between mb-6">
        <button onClick={() => setStep(1)} className="p-2 bg-slate-900 rounded-full border border-slate-800 hover:border-slate-600"><ArrowLeft className="w-5 h-5 text-slate-400" /></button>
