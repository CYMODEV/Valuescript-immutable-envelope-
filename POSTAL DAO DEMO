            {activeTab === 'profile' && <ProfileView isPro={isPro} togglePro={togglePro} isMobileMode={isMobileMode} />}
            
            {showLogs && <GlassBoxLog logs={sysLogs} onClose={() => setShowLogs(false)} />}
