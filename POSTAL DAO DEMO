const apiKey = ""; // Injected at runtime

// Helper to strip markdown code blocks from JSON responses
const cleanJson = (text) => {
  if (!text) return text;
  return text.replace(/```json\n?|\n?```/g, "").trim();
};

const generateText = async (prompt, docType) => {
  try {
    if (!apiKey) throw new Error("No API Key");
    const typeContext = docType ? `Context: This is a ${docType} document requiring secure custody language.` : "";
    const response = await fetch(
      `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`,
      {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          contents: [{ parts: [{ text: `Write a short, professional message (under 100 words) for a letter. ${typeContext} Prompt: ${prompt}` }] }]
        })
      }
    );
    const data = await response.json();
    return data.candidates?.[0]?.content?.parts?.[0]?.text || "Could not generate text.";
  } catch (e) {
    console.error("Gemini Text Error:", e);
    return `[Mock AI Draft]: Regarding your recent inquiry about ${prompt}, we acknowledge receipt and will process accordingly.`;
  }
};

