const MailDesk = ({ userStamps, onSendMail, isPro, initialMessage, clearInitialMessage, isPurseLocked, isMobileMode }) => {
  const [step, setStep] = useState(1);
  const [mailType, setMailType] = useState(null);
  const [docType, setDocType] = useState(null); 
  const [selectedStamp, setSelectedStamp] = useState(null);
  const [recipient, setRecipient] = useState("");
  const [message, setMessage] = useState("");
  const [isSealing, setIsSealing] = useState(false);
  const [isVerifying, setIsVerifying] = useState(false);
  const [isDragging, setIsDragging] = useState(false);
  const [dragPosition, setDragPosition] = useState({ x: 0, y: 0 });
  
  // Sovereign States
  const [isSovereignMode, setIsSovereignMode] = useState(false);
  const [gpsCoords, setGpsCoords] = useState({ lat: "", lng: "" });
  const [utilityAddress, setUtilityAddress] = useState("");

  // AI States
  const [aiPrompt, setAiPrompt] = useState("");
  const [isAiGenerating, setIsAiGenerating] = useState(false);
  const [isFormalizing, setIsFormalizing] = useState(false);
  const [showAiInput, setShowAiInput] = useState(false);
  const [showClauseInput, setShowClauseInput] = useState(false); 
  const [showStyleInput, setShowStyleInput] = useState(false); 
  const [isParsingAddr, setIsParsingAddr] = useState(false);
  const [showTranslate, setShowTranslate] = useState(false);
  
  // NEW: Risk & Vibe State
  const [riskReport, setRiskReport] = useState(null);
  const [isRiskScanning, setIsRiskScanning] = useState(false);
  const [vibeReport, setVibeReport] = useState(null);
  const [isVibeScanning, setIsVibeScanning] = useState(false);

  // DRAG REFS
  const dragItemRef = useRef(null);
  const dropZoneRef = useRef(null);

  // Handle incoming draft from Mailbox
  useEffect(() => {
      if (initialMessage) {
          setMailType('electronic');
          setDocType('Legal'); // Default for auto-counsel
          setMessage(initialMessage);
          setStep(2);
          clearInitialMessage();
      }
  }, [initialMessage, clearInitialMessage]);

  const mintStamps = userStamps.filter(s => s.status === 'mint');

  // ... (AI Handlers kept same)
  const handleAiDraft = async () => {
    if (!aiPrompt.trim()) return;
    setIsAiGenerating(true);
    const text = await generateText(aiPrompt, docType);
    setMessage(text);
    setIsAiGenerating(false);
    setShowAiInput(false);
    setAiPrompt("");
  };

  const handleInsertClause = async () => {
      if (!aiPrompt.trim()) return;
      setIsAiGenerating(true);
      const clause = await generateClauseAi(aiPrompt, docType);
      setMessage(prev => prev + (prev ? "\n\n" : "") + clause);
      setIsAiGenerating(false);
      setShowClauseInput(false);
      setAiPrompt("");
  };

  const handleFormalize = async () => {
      if (!message.trim()) return;
      setIsFormalizing(true);
      const refined = await formalizeText(message, docType);
      setMessage(refined);
      setIsFormalizing(false);
  };

  const handleStyleRewrite = async (style) => {
      if (!message.trim()) return;
      setIsAiGenerating(true);
      const styled = await rewriteStyleAi(message, style);
      setMessage(styled);
      setIsAiGenerating(false);
      setShowStyleInput(false);
  };
  
  const handleTranslate = async (lang) => {
      if (!message.trim()) return;
      setIsAiGenerating(true);
      const translated = await translateTextAi(message, lang, docType);
      setMessage(translated);
      setIsAiGenerating(false);
      setShowTranslate(false);
  };
  
  const handleRiskScan = async () => {
      if (!message.trim()) return;
      setIsRiskScanning(true);
      const report = await analyzeRiskAi(message);
      setRiskReport(report);
      setIsRiskScanning(false);
  };

  const handleVibeCheck = async () => {
      if (!message.trim()) return;
      setIsVibeScanning(true);
      const vibe = await analyzeVibeAi(message);
      setVibeReport(vibe);
      setIsVibeScanning(false);
      // Auto-hide after 3s
      setTimeout(() => setVibeReport(null), 4000);
  };

  const handleSmartPaste = async () => {
      const text = await  navigator.clipboard.readText().catch(() => "");
      if(!text) { alert("Clipboard empty or permission denied"); return; }
      
      setIsParsingAddr(true);
      const formatted = await parseAddressAi(text);
      setRecipient(formatted);
      setIsParsingAddr(false);
  };

  const handleGetLocation = () => {
      if(!navigator.geolocation) { alert("Not supported"); return; }
      navigator.geolocation.getCurrentPosition((pos) => {
          setGpsCoords({ lat: pos.coords.latitude.toFixed(6), lng: pos.coords.longitude.toFixed(6) });
      });
  };

  const handleDragStart = (e, stamp) => {
    // Basic drag init
    if (isPurseLocked) return;
    triggerHaptic([20]); // Pickup haptic
    
    // Calculate initial position relative to viewport
    // For simplicity in this demo, we'll track pointer directly
    const clientX = e.touches ? e.touches[0].clientX : e.clientX;
    const clientY = e.touches ? e.touches[0].clientY : e.clientY;
    
    setDragPosition({ x: clientX, y: clientY });
    setSelectedStamp(stamp); // "Hold" this stamp
    setIsDragging(true);
  };

  const handleDragMove = (e) => {
    if (!isDragging) return;
    const clientX = e.touches ? e.touches[0].clientX : e.clientX;
    const clientY = e.touches ? e.touches[0].clientY : e.clientY;
    setDragPosition({ x: clientX, y: clientY });
  };

  const handleDragEnd = (e) => {
    if (!isDragging) return;
    setIsDragging(false);
    
    // Check drop zone collision
    const dropZone = dropZoneRef.current.getBoundingClientRect();
    const x = dragPosition.x;
    const y = dragPosition.y;

    // Check if pointer is inside envelope rect
    if (x >= dropZone.left && x <= dropZone.right && y >= dropZone.top && y <= dropZone.bottom) {
        triggerHaptic([30, 50]); // Drop success
        // Stamp is now "Placed" (selectedStamp stays set)
    } else {
        // Returned to tray
        setSelectedStamp(null);
    }
  };


  const handleSeal = async () => {
    if (isPurseLocked) {
        alert("ePurse is LOCKED. Please unlock in Vault tab to authorize transactions.");
        return;
    }
    triggerHaptic([50, 50, 50]);
    setIsSealing(true);
    setIsVerifying(true);
    await ComplianceEngine.checkKCZ(selectedStamp.id);
