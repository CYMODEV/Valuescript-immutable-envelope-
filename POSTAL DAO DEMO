                            className="text-[10px] text-slate-400 hover:text-slate-200 flex items-center gap-1"
                        >
                            {isParsingAddr ? <Loader2 className="w-3 h-3 animate-spin" /> : <Wand2 className="w-3 h-3" />}
                            Smart Paste
