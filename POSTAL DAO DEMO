                    <button onClick={() => setIsSovereignMode(!isSovereignMode)} className="text-[10px] text-cyan-500 hover:underline flex items-center gap-1"><Crosshair className="w-3 h-3" /> {isSovereignMode ? "Switch to Standard" : "Switch to GPS"}</button>
