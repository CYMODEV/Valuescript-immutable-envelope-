const App = () => {
  const [activeTab, setActiveTab] = useState('desk');
  const [isPro, setIsPro] = useState(false);
  const [balance, setBalance] = useState(INITIAL_BALANCE);
  const [userStamps, setUserStamps] = useState(INITIAL_VAULT);
  const [inventory, setInventory] = useState(INITIAL_MARKET);
  const [draftMessage, setDraftMessage] = useState(""); 
  const [transactions, setTransactions] = useState(INITIAL_TRANSACTIONS); 
  const [isPurseLocked, setIsPurseLocked] = useState(false); 
  
  // Format Toggle State
  const [isMobileMode, setIsMobileMode] = useState(true);
  
  // LOGS STATE
  const [showLogs, setShowLogs] = useState(false);
  const [sysLogs, setSysLogs] = useState([]);

  // Fix for potential Tailwind CDN configuration issues
  useEffect(() => {
    if (typeof window !== 'undefined' && window.tailwind) {
      window.tailwind.config = {
        theme: {
          extend: {
            colors: {
              slate: { 950: '#020617' } // Ensure slate-950 exists
            }
          }
        }
      }
    }
  }, []);

  const addLog = (msg, layer='RING', type='info') => {
      const time = new Date().toLocaleTimeString('en-US', { hour12: false, hour: "2-digit", minute: "2-digit", second: "2-digit" });
      setSysLogs(prev => [...prev, { time, msg, layer, type }]);
  };
  
  const pendingCount = userStamps.filter(s => s.status === 'locked').length;

  const handleBuy = (stamp) => {
    if (balance >= stamp.price) {
      if (isPurseLocked) { alert("Wallet Locked"); return; }
      setBalance(prev => prev - stamp.price);
      const newStamp = { ...stamp, uniqueId: Date.now(), status: "mint", acquiredDate: "Just now" };
      setUserStamps(prev => [newStamp, ...prev]);
      
      const newTx = { id: Date.now(), type: 'purchase', amount: -stamp.price, date: 'Just now', desc: `Mint: ${stamp.title}` };
      setTransactions(prev => [newTx, ...prev]);

      triggerHaptic(50);
      addLog(`MINT: User purchased '${stamp.title}'`, 'RING', 'success');
    }
  };

  const handleAddAiStamp = (newStampData) => {
      // Check balance for mint fee
      if (balance < newStampData.mintFee) {
          alert("Insufficient USDB for minting fee.");
          return;
      }

      // Deduct Fee
      setBalance(prev => prev - newStampData.mintFee);
      
      // Log Transaction
      const newTx = { 
          id: Date.now(), 
          type: 'fee', 
          amount: -newStampData.mintFee, 
          date: 'Just now', 
          desc: `Mint Fee: ${newStampData.title}` 
      };
      setTransactions(prev => [newTx, ...prev]);

      // Mint Asset (Add to User Vault)
      const stamp = {
          uniqueId: Date.now(),
          id: Date.now(),
          title: newStampData.title,
          status: "mint",
          acquiredDate: "Just now",
          image: newStampData.image,
          isAiGenerated: true,
          artist: newStampData.artist, // "Me (Creator)"
          price: newStampData.faceValue,
          supply: newStampData.supply
      };
      setUserStamps(prev => [stamp, ...prev]);
      
      setActiveTab('vault');
      triggerHaptic(100);
      addLog(`CREATOR: Minted Series '${newStampData.title}' on RingMint`, 'RING', 'success');
      addLog(`SMART_CONTRACT: Supply Cap set to ${newStampData.supply}, Royalty ${newStampData.royalty}%`, 'RING');
      addLog(`EPURSE: Gas/Mint Fee $${newStampData.mintFee} USDB`, 'CORE', 'warning');
  };

  const handleUnlockGeofence = (uniqueId, success, coords) => {
      if (success) {
          addLog(`GEOFENCE: Validated at ${coords.latitude},${coords.longitude}`, 'CORE', 'success');
          setUserStamps(prev => prev.map(s => s.uniqueId === uniqueId ? { ...s, status: 'cancelled' } : s));
      }
  };

  const handleComposeReply = (text) => {
      setDraftMessage(text);
      setActiveTab('desk');
      addLog(`AUTO-COUNSEL: Draft Response Generated`, 'CORE', 'success');
  };

  const handleTopUp = () => {
      if (isPurseLocked) { alert("Wallet Locked"); return; }
      const amount = 100.00;
      setBalance(prev => prev + amount);
      const newTx = { id: Date.now(), type: 'deposit', amount: amount, date: 'Just now', desc: 'Top Up (USDB)' };
      setTransactions(prev => [newTx, ...prev]);
      triggerHaptic(50);
      addLog(`EPURSE: Deposit ${amount} USDB`, 'CORE', 'success');
  };

  const handleWithdraw = () => {
      if (isPurseLocked) { alert("Wallet Locked"); return; }
      if (balance <= 0) return;
      const amount = 50.00;
      if (balance < amount) return;
      setBalance(prev => prev - amount);
      const newTx = { id: Date.now(), type: 'withdraw', amount: -amount, date: 'Just now', desc: 'Withdraw to External' };
      setTransactions(prev => [newTx, ...prev]);
      triggerHaptic(50);
      addLog(`EPURSE: Withdraw ${amount} USDB`, 'CORE', 'warning');
  };
  
  const handlePayout = () => {
      if (isPurseLocked) { alert("Wallet Locked"); return; }
      const earnings = 124.50; // Mock earnings from dashboard
      setBalance(prev => prev - earnings); // In this demo, earnings are simulated as already in balance, but we'll show a payout action
      // In a real app, earnings would be a separate ledger entry that transfers TO balance or OUT to wallet.
      // Here we simulate withdrawing SPECIFICALLY the creator earnings.
      const newTx = { id: Date.now(), type: 'payout', amount: -earnings, date: 'Just now', desc: 'Creator Payout' };
      setTransactions(prev => [newTx, ...prev]);
      triggerHaptic(50);
      addLog(`EPURSE: Creator Payout $${earnings} USDB to Cold Wallet`, 'CORE', 'success');
  };

  const togglePro = () => {
      if (!isPro) {
          if (balance >= SUB_PRICE) {
              setBalance(prev => prev - SUB_PRICE);
              const newTx = { id: Date.now(), type: 'subscription', amount: -SUB_PRICE, date: 'Just now', desc: 'Pro Membership' };
              setTransactions(prev => [newTx, ...prev]);
              setIsPro(true);
          }
      } else {
          setIsPro(false);
      }
  };

  const handleSendMail = ({ type, recipient, stampUniqueId, docType, isGeofenced, gpsCoordinates }) => {
      // HYBRID LEDGER SIMULATION & VALUE SCRIPT LOGIC
      
      // 1. Initial Lock (Ring)
      addLog(`ESCROW: Locking Stamp ID ${stampUniqueId} on Public Ledger`, 'RING');

      // 2. Value Script Execution (Based on Doc Type & Features)
      if (isGeofenced) {
          addLog(`SCRIPT [Secret]: Splitting Decryption Key (Shamir's Secret Sharing)...`, 'CORE');
          setTimeout(() => addLog(`SCRIPT [Secret]: Geofence Hash Registered on Chain`, 'RING', 'success'), 800);
          setTimeout(() => addLog(`SCRIPT [Secret]: Burn-on-Read Timer Armed`, 'CORE', 'error'), 1600);
      } else if (docType === 'Legal') {
          addLog(`SCRIPT [Legal]: Generating Timestamp Anchor...`, 'RING');
          setTimeout(() => addLog(`SCRIPT [Legal]: Verifying Sender Identity via Oracle...`, 'CORE', 'success'), 500);
          setTimeout(() => addLog(`SCRIPT [Legal]: Chain of Custody Token Minted`, 'RING', 'success'), 1200);
      } else if (docType === 'Financial') {
          addLog(`SCRIPT [Financial]: Wrapping Asset as RingMint Bearer Instrument...`, 'RING');
          setTimeout(() => addLog(`SCRIPT [Financial]: Initializing Atomic Swap Escrow`, 'CORE', 'success'), 800);
      } else if (docType === 'Medical') {
          addLog(`SCRIPT [Medical]: Encrypting Payload (AES-256)...`, 'CORE');
          setTimeout(() => addLog(`SCRIPT [Medical]: Generating Zero-Knowledge Proof...`, 'RING', 'success'), 800);
      }

      setUserStamps(prev => prev.map(s => {
          if (s.uniqueId === stampUniqueId) {
              return { 
                  ...s, 
                  status: isGeofenced ? 'geofenced' : 'locked', 
                  trackingHash: generateHash(), 
                  destination: recipient, 
                  lockedAt: Date.now(),
                  targetGps: isGeofenced ? gpsCoordinates : null
                };
          }
          return s;
      }));
  };

  return (
    <div className={`flex ${isMobileMode ? 'flex-col' : 'flex-row'} h-screen bg-slate-950 font-sans text-slate-200 overflow-hidden select-none`}>
      <style>{`
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes slideUp { from { transform: translateY(40px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
        @keyframes bounceShort { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-5px); } }
        .animate-fade-in { animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
        .animate-slide-up { animation: slideUp 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
        .animate-scale-up { animation: fadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1); }
        .animate-bounce-short { animation: bounceShort 1.5s infinite; }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
      `}</style>

      {isMobileMode ? (
          <MobileHeader isPro={isPro} balance={balance} onOpenLogs={() => setShowLogs(!showLogs)} isPurseLocked={isPurseLocked} />
      ) : (
          <DesktopSidebar activeTab={activeTab} setActiveTab={setActiveTab} pendingCount={pendingCount} />
      )}
      
      <main className={`flex-1 overflow-y-auto overscroll-contain relative bg-slate-950 ${isMobileMode ? '' : 'p-8'}`}>
        <div className={isMobileMode ? '' : 'max-w-7xl mx-auto'}>
            {/* Header for Desktop Web Mode */}
            {!isMobileMode && (
                <div className="flex justify-between items-center mb-8 border-b border-slate-800 pb-6">
                    <h2 className="text-2xl font-bold text-slate-100 capitalize">{activeTab} Dashboard</h2>
                    <div className="flex items-center gap-4">
                        <div className="px-4 py-2 bg-slate-900 border border-slate-800 rounded-xl flex items-center gap-3">
                            <span className="text-xs font-bold text-slate-500 uppercase tracking-widest">Balance</span>
                            <span className="text-lg font-mono font-bold text-emerald-400">${balance.toFixed(2)}</span>
                        </div>
                        <button onClick={() => setShowLogs(!showLogs)} className="p-2 bg-slate-900 rounded-xl border border-slate-800 hover:text-white text-slate-400"><Terminal className="w-5 h-5" /></button>
                        {isPurseLocked && <Lock className="w-5 h-5 text-red-500" />}
                    </div>
                </div>
            )}

            {activeTab === 'market' && <MarketView inventory={inventory} onBuy={handleBuy} balance={balance} isPro={isPro} isMobileMode={isMobileMode} />}
            {activeTab === 'vault' && <EPurseView userStamps={userStamps} balance={balance} onUnlockGeofence={handleUnlockGeofence} transactions={transactions} onTopUp={handleTopUp} onWithdraw={handleWithdraw} onPayout={handlePayout} isLocked={isPurseLocked} setIsLocked={setIsPurseLocked} isMobileMode={isMobileMode} />}
            {activeTab === 'desk' && <MailDesk userStamps={userStamps} onSendMail={handleSendMail} isPro={isPro} initialMessage={draftMessage} clearInitialMessage={() => setDraftMessage("")} isPurseLocked={isPurseLocked} isMobileMode={isMobileMode} />}
